      propertyPath: 'characterLines.Array.data[7]'
      value: '*coughs*'
      objectReference: {fileID: 0}
    - target: {fileID: 129979084875831417, guid: 2cbd95f064d6b814e8767afc0211af69, type: 3}
      propertyPath: 'characterLines.Array.data[8]'
      value: It's my fault you got injured. I'm so sorry.
      objectReference: {fileID: 0}
    - target: {fileID: 129979084875831417, guid: 2cbd95f064d6b814e8767afc0211af69, type: 3}
