      propertyPath: 'characterLines.Array.data[5]'
      value: 'I shouldn''t have left your side in that ancient ruins... '
      objectReference: {fileID: 0}
    - target: {fileID: 129979084875831417, guid: 2cbd95f064d6b814e8767afc0211af69, type: 3}
      propertyPath: 'characterLines.Array.data[6]'
