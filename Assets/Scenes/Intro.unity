      propertyPath: 'characterLines.Array.data[0]'
      value: '*Hospital Room #666*'
      objectReference: {fileID: 0}
    - target: {fileID: 129979084875831417, guid: 2cbd95f064d6b814e8767afc0211af69, type: 3}
      propertyPath: 'characterLines.Array.data[1]'
      value: '*A hispanic young male lays in bed, many severe cuts and gashes spread
        across his body* '
      objectReference: {fileID: 0}
    - target: {fileID: 129979084875831417, guid: 2cbd95f064d6b814e8767afc0211af69, type: 3}
      propertyPath: 'characterLines.Array.data[2]'
      value: '*An asian young female by his side, sitting in a chair in deep sorrow* '
      objectReference: {fileID: 0}
    - target: {fileID: 129979084875831417, guid: 2cbd95f064d6b814e8767afc0211af69, type: 3}
      propertyPath: 'characterLines.Array.data[3]'
      value: 'Diego... '
      objectReference: {fileID: 0}
    - target: {fileID: 129979084875831417, guid: 2cbd95f064d6b814e8767afc0211af69, type: 3}
      propertyPath: 'characterLines.Array.data[4]'
